# Hermes Marvis Frontend Configuration
# Copy to .env.local and fill in your values. NEVER commit .env.local.

# Hermes API bearer key (RSA public key used to sign session tokens).
# Generate a new one if you suspect it has been leaked; previous keys must
# be revoked on the Hermes backend before rotating.
VITE_HERMES_API_KEY=

# Optional: Cron / System API bearer key (if cron-server requires auth).
# Leave empty if cron-server runs without authentication (local-only).
VITE_CRON_API_KEY=

# Optional: Allowed origin for Obsidian vault server (default: http://localhost:5173).
# Set to '*' only for local development — never use '*' in production.
OBSIDIAN_ALLOWED_ORIGIN=
