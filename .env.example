# Hermes Marvis Frontend Configuration
# Copy to .env.local and fill in your values. NEVER commit .env.local.

# Hermes API bearer key (shared-secret, >= 16 chars).
# Cron job management (/api/jobs) uses this same key.
VITE_HERMES_API_KEY=

# Optional: System/Settings API bearer key (cron-server on port 8644).
# Only needed for system info (drives, WSL) and settings management.
# Leave empty if not using these features.
VITE_CRON_API_KEY=

# Optional: Allowed origin for Obsidian vault server (default: http://localhost:5173).
# Set to '*' only for local development — never use '*' in production.
OBSIDIAN_ALLOWED_ORIGIN=
